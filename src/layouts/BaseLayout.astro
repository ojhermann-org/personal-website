---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Otto Hermann",
  description = "Otto Hermann's personal website.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
